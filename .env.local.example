# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# MoonPay — get from https://dashboard.moonpay.com (add when ready)
NEXT_PUBLIC_MOONPAY_API_KEY=your-moonpay-publishable-key
MOONPAY_SECRET_KEY=your-moonpay-secret-key

# Exchange rate API — free tier at https://exchangerate-api.com
EXCHANGE_RATE_API_KEY=your-exchange-rate-key

# WhatsApp (Meta Cloud API) — get from https://developers.facebook.com
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=pick-any-secret-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "demo" to show "Demo only" banner (no real money transmission)
NEXT_PUBLIC_APP_MODE=

# Admin (optional — for KYC review at /admin)
ADMIN_EMAIL=your-admin@email.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
